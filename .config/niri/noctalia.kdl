layout {

    focus-ring {
        active-color   "#5e81ac"
        inactive-color "#eceff4"
        urgent-color   "#bf616a"
    }

    border {
        active-color   "#5e81ac"
        inactive-color "#eceff4"
        urgent-color   "#bf616a"
    }

    shadow {
        color "#d8dee970"
    }

    tab-indicator {
        active-color   "#5e81ac"
        inactive-color "#cdd8e4"
        urgent-color   "#bf616a"
    }

    insert-hint {
        color "#5e81ac80"
    }
}

recent-windows {
    highlight {
        active-color "#5e81ac"
        urgent-color "#bf616a"
    }
}
